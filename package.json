{
  "name": "gridix",
  "version": "1.0.0",
  "description": "A DataTables alternative — AEM-compatible, TypeScript-first table plugin",
  "keywords": [
    "table",
    "datatable",
    "sorting",
    "filtering",
    "pagination",
    "aem",
    "typescript",
    "accessible",
    "responsive",
    "dark-mode"
  ],
  "author": "Aditya B",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityakahb/gridix.git"
  },
  "bugs": {
    "url": "https://github.com/adityakahb/gridix/issues"
  },
  "homepage": "https://adityakahb.github.io/gridix",
  "main": "dist/scripts/gridix.cjs.js",
  "module": "dist/scripts/gridix.esm.js",
  "types": "dist/gridix.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/scripts/gridix.esm.js",
      "require": "./dist/scripts/gridix.cjs.js",
      "types": "./dist/gridix.d.ts"
    },
    "./style": "./dist/styles/gridix.css",
    "./style/min": "./dist/styles/gridix.min.css"
  },
  "files": ["dist", "src/connectors"],
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "rollup -c rollup.config.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "vite --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"tests/**/*.ts\" \"demos/**/*.html\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"tests/**/*.ts\"",
    "lint": "eslint src tests",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.5.0",
    "jsdom": "^24.1.0",
    "lightningcss": "^1.28.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.7",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "stylelint": "^16.6.0",
    "stylelint-config-standard": "^36.0.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
